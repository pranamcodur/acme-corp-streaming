<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= companyName %> | Data Streaming</title>
    
    <script src="https://plug-platform.devrev.ai/static/plug.js" type="text/javascript"></script>
    
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav>
        <div class="logo"><strong><%= companyName %></strong></div>
        <ul>
            <li>Products</li>
            <li>Solutions</li>
            <li>Docs</li>
        </ul>
    </nav>

    <header class="hero">
        <h1><%= tagline %></h1>
        <p>The backbone for modern event-driven architectures.</p>
        <button class="cta">Start Streaming Free</button>
    </header>

    <section class="features">
        <% services.forEach(service => { %>
            <div class="card">
                <h3><%= service %></h3>
                <p>Enterprise-grade performance for <%= service.toLowerCase() %>.</p>
            </div>
        <% }); %>
    </section>

    <script>
      window.plugSDK.init({
        app_id: 'DvRvStPZG9uOmNvcmU6ZHZydi11cy0xOmRldm8vMVpNUFRhdjFubjpwbHVnX3NldHRpbmcvMV9ffHxfXzIwMjYtMDUtMDggMDg6NTA6MjguNTY2OTg3NjUgKzAwMDAgVVRDxlxendsDvRv',
      });
    </script>
</body>
</html>
